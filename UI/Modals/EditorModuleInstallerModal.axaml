<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Modals.EditorModuleInstallerModal"
  xmlns:models="clr-namespace:Models.Data;assembly=Models" x:DataType="models:EditorInfo"
  xmlns:controls="clr-namespace:UI.Controls">
  <Border Background="{DynamicResource BackgroundColourDark}" BorderThickness="1" BorderBrush="{DynamicResource ButtonBorder}" CornerRadius="20">
    <Grid RowDefinitions="50 Auto * Auto" Margin="20">
      <Label Content="{Binding versionName}"/>

      <StackPanel Grid.Row="1" Spacing="5">
        <Grid ColumnDefinitions="200 *">
          <Label>Install Location</Label>
          <ComboBox Grid.Column="1" HorizontalAlignment="Stretch" x:Name="inp_Locations"/>
        </Grid>
      </StackPanel>

      <StackPanel Grid.Row="2" x:Name="test">

      </StackPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="3">
        <controls:ButtonWrapper Label="Install" Classes="Primary" Width="100" x:Name="btn_Install"/>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
