<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Modals.CreateProjectModal_Package"
  xmlns:models="clr-namespace:Models.Data;assembly=Models" x:DataType="models:EditorInstallInfo+BuiltInPackage">
  <StackPanel Orientation="Horizontal">
    <CheckBox x:Name="inp_Select" VerticalAlignment="Center"/>
    <Label Content="{Binding displayName}" VerticalAlignment="Center"/>
    <Label Content="{Binding name}" FontSize="10" FontStyle="Italic" VerticalAlignment="Center"/>
  </StackPanel>
</UserControl>
