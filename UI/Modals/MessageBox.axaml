<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Modals.MessageBox" x:Name="root"
  xmlns:controls="clr-namespace:UI.Controls">
  <Border Background="{DynamicResource BackgroundColourLight}" BorderThickness="1" BorderBrush="{DynamicResource BackgroundBorder}" CornerRadius="{DynamicResource CornerRadius_Menu}" MinWidth="250" MinHeight="150">
    <Grid RowDefinitions="Auto * Auto" Margin="10">
      <Label Content="{Binding #root.Header}" Grid.Row="0" HorizontalAlignment="Center" FontSize="20"/>
      <TextBlock Text="{Binding #root.Paragraph}" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0 5"/>

      <StackPanel HorizontalAlignment="Right" Grid.Row="2">
        <controls:ButtonWrapper Label="Ok" x:Name="btn_ok" Classes="Primary"/>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
