<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Modals.ConfirmationBox"
  xmlns:controls="clr-namespace:UI.Controls" x:Name="root">
  <Border Background="{DynamicResource BackgroundColourLight}" BorderThickness="1" BorderBrush="{DynamicResource BackgroundBorder}" CornerRadius="{DynamicResource CornerRadius_Menu}" MinWidth="250" MinHeight="150">
    <Grid RowDefinitions="Auto * Auto" Margin="10">
      <Label Content="{Binding #root.Header}" HorizontalAlignment="Center" Grid.Row="0" FontSize="20"/>
      <TextBlock Text="{Binding #root.Body}" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1"/>

      <StackPanel HorizontalAlignment="Right" Grid.Row="2" x:Name="cont_Btns" Orientation="Horizontal" Spacing="5"/>
    </Grid>
  </Border>
</UserControl>
