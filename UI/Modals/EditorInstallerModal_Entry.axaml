<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Modals.EditorInstallerModal_Entry"
  xmlns:models="clr-namespace:Models.Data;assembly=Models" x:DataType="models:EditorInfo"
  xmlns:controls="clr-namespace:UI.Controls">
  <Border>
    <Grid ColumnDefinitions="* 10 Auto">
      <Label Content="{Binding versionName}"/>
      <controls:ButtonWrapper x:Name="btn_Install" Label="Install" Classes="Primary" Grid.Column="2"/>
    </Grid>
  </Border>
</UserControl>
