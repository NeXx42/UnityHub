<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Controls.Sidebar"
  xmlns:local="clr-namespace:UI.Controls" Width="225">
  <Border BorderThickness="0 0 1 0" BorderBrush="{DynamicResource ButtonBorder}">
    <Grid RowDefinitions="Auto 1 * 1 50" Background="{DynamicResource BackgroundColourDark}">
      <!-- icon -->
      <Grid VerticalAlignment="Center" Margin="15">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <Viewbox Height="30">
            <Path Fill="{DynamicResource AccentColour}" Data="M15.528 2.973a.75.75 0 0 1 .472.696v8.662a.75.75 0 0 1-.472.696l-7.25 2.9a.75.75 0 0 1-.557 0l-7.25-2.9A.75.75 0 0 1 0 12.331V3.669a.75.75 0 0 1 .471-.696L7.443.184l.01-.003.268-.108a.75.75 0 0 1 .558 0l.269.108.01.003zM10.404 2 4.25 4.461 1.846 3.5 1 3.839v.4l6.5 2.6v7.922l.5.2.5-.2V6.84l6.5-2.6v-.4l-.846-.339L8 5.961 5.596 5l6.154-2.461z"/>
          </Viewbox>

          <StackPanel Orientation="Vertical">
            <Label Content="Unity Hub" Foreground="{DynamicResource TextColour}" FontSize="18"/>
            <Label Content="Project Manager" FontSize="10" Foreground="{DynamicResource TextColourMuted}"/>
          </StackPanel>
        </StackPanel>
      </Grid>

      <Border Background="{DynamicResource ButtonBorder}" Grid.Row="1" HorizontalAlignment="Stretch" Margin="8 0"/>

      <!-- icon -->
      <ContentPresenter x:Name="content" Grid.Row="2"/>

      <Border Background="{DynamicResource ButtonBorder}" Grid.Row="3" HorizontalAlignment="Stretch" Margin="8 0"/>

      <!-- Buttons -->
      <Grid Grid.Row="4">
        <StackPanel Orientation="Horizontal" Margin="10" Spacing="10" HorizontalAlignment="Center">
          <local:ButtonWrapper Classes="Transparent" x:Name="btn_Home">
            <local:ButtonWrapper.Icon>
              <Viewbox Width="14" Height="14">
                <Path Data="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293zM13 7.207V13.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V7.207l5-5z"/>
              </Viewbox>
            </local:ButtonWrapper.Icon>
          </local:ButtonWrapper>

          <Border Height="20" Width="1" Background="{DynamicResource TextColourMuted}" />

          <local:ButtonWrapper Classes="Transparent" x:Name="btn_Settings">
            <local:ButtonWrapper.Icon>
              <Viewbox Width="14" Height="14">
                <Grid>
                  <Path Data="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492M5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0"/>
                  <Path Data="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.291-.16c.764-.415 1.6.42 1.184 1.185l-.159.292a1.873 1.873 0 0 0 1.116 2.692l.318.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.291c.415.764-.42 1.6-1.185 1.184l-.291-.159a1.873 1.873 0 0 0-2.693 1.116l-.094.318c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.692-1.115l-.292.16c-.764.415-1.6-.42-1.184-1.185l.159-.291A1.873 1.873 0 0 0 1.945 8.93l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094A1.873 1.873 0 0 0 3.06 4.377l-.16-.292c-.415-.764.42-1.6 1.185-1.184l.292.159a1.873 1.873 0 0 0 2.692-1.115z"/>
                </Grid>
              </Viewbox>
            </local:ButtonWrapper.Icon>
          </local:ButtonWrapper>

          <Border Height="20" Width="1" Background="{DynamicResource TextColourMuted}" />

          <local:ButtonWrapper Classes="Transparent" x:Name="btn_Downloads" PopupPlacementTarget="Top">
            <local:ButtonWrapper.Icon>
              <Grid Width="16" Height="25">
                <ProgressBar Value=".5" Minimum="0" Maximum="1" Height="3" Width="25" MinHeight="0" VerticalAlignment="Bottom" x:Name="inp_DownloadProgress" MinWidth="0"></ProgressBar>
                <Viewbox >
                  <Grid>
                    <Path Data="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
                    <Path Data="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/>
                  </Grid>
                </Viewbox>
              </Grid>
            </local:ButtonWrapper.Icon>
          </local:ButtonWrapper>
        </StackPanel>
      </Grid>

    </Grid>
  </Border>
</UserControl>
