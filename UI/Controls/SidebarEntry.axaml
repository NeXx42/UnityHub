<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Controls.SidebarEntry" x:Name="root">
  <UserControl.Styles>
    <Style Selector="UserControl.Selected">
      <Setter Property="Background" Value="Red"/>
    </Style>
  </UserControl.Styles>

  <Border x:Name="cont_Border" Padding="10">
    <Grid>
      <StackPanel Orientation="Horizontal">
        <Viewbox >
          <ContentPresenter Content="{Binding #root.Icon}"/>
        </Viewbox>
        <Label Content="{Binding #root.Label}"/>
      </StackPanel>
      <Label HorizontalAlignment="Right">128</Label>
    </Grid>
  </Border>
</UserControl>
