<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Controls.SidebarCollectionEntry"
  xmlns:local="clr-namespace:UI.Controls" x:Name="root">
  <UserControl.Styles>
    <Style Selector="UserControl.Selected > Grid > Border">
      <Setter Property="Background" Value="Red"/>
    </Style>
  </UserControl.Styles>
  <StackPanel Orientation="Vertical">
    <local:SidebarEntry Label="{Binding #root.Label}" Icon="{Binding #root.Icon}"/>

    <StackPanel x:Name="container">
    </StackPanel>
  </StackPanel>

</UserControl>
