<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Pages.Settings.Pages.SettingsPage_Editors"
  xmlns:controls="clr-namespace:UI.Controls">
  <StackPanel Orientation="Vertical" Spacing="20">
    <StackPanel Spacing="5">
      <Label FontSize="20">Install Locations</Label>
      <Grid RowDefinitions="* 5 Auto">
        <StackPanel x:Name="cont_Locations"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2">
          <controls:ButtonWrapper Label="Add" x:Name="btn_AddLocation" Classes="Primary" Width="100" HorizontalContentAlignment="Center"/>
        </StackPanel>
      </Grid>
    </StackPanel>

    <StackPanel Spacing="5">
      <Label FontSize="20">Installed Version</Label>
      <Grid RowDefinitions="* 5 Auto">
        <StackPanel x:Name="cont_Versions" Spacing="5"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="5" Grid.Row="2">
          <controls:ButtonWrapper Label="Install" Classes="Primary" Width="100" x:Name="btn_InstallVersion" HorizontalContentAlignment="Center"/>
        </StackPanel>
      </Grid>
    </StackPanel>

  </StackPanel>
</UserControl>
