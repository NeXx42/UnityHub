<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Pages.Settings.Pages.SettingsPage_Themes"
  xmlns:common="clr-namespace:UI.Pages.Settings.Pages.Common">
  <StackPanel Orientation="Vertical" Spacing="5">
    <Label FontSize="20">Colours</Label>

    <Grid ColumnDefinitions="Auto * 200">
      <Label>Theme</Label>
      <ComboBox x:Name="inp_ThemeDropdown" Grid.Column="3"/>
    </Grid>
  </StackPanel>
</UserControl>
