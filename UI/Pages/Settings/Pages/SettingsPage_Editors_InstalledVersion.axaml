<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Pages.Settings.Pages.SettingsPage_Editors_InstalledVersion" x:Name="root"
  xmlns:models="clr-namespace:Models.Data;assembly=Models" x:DataType="models:DownloadStatus"
  xmlns:controls="clr-namespace:UI.Controls">
  <Border Background="{DynamicResource ElementBackground}" BorderThickness="1" BorderBrush="{DynamicResource ButtonBorder}" CornerRadius="8">
    <StackPanel Orientation="Vertical" Margin="10">
      <Grid ColumnDefinitions="Auto Auto * Auto">
        <Label Content="{Binding #root.ProductName}" VerticalAlignment="Center" />
        <StackPanel x:Name="cont_Tags" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center" Grid.Column="1"/>

        <controls:ButtonWrapper VerticalAlignment="Center" Grid.Column="4" Classes="Transparent" x:Name="btn_Extra">
          <controls:ButtonWrapper.Icon>
            <Viewbox Height="12">
              <Path Fill="{DynamicResource TextColour}" Data="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0" />
            </Viewbox>
          </controls:ButtonWrapper.Icon>
        </controls:ButtonWrapper >
      </Grid>

      <Grid>
        <Grid Grid.Row="1" x:Name="cont_DownloadStatus" ColumnDefinitions="* 50">
          <ProgressBar Minimum="0" Maximum="1" Value="{Binding currentValue}" Margin="0 0 5 0" />
          <Label Content="{Binding getPercentageName}" Grid.Column="1"/>
        </Grid>

        <Label Grid.Row="1" Content="{Binding #root.InstallLocation}" Margin="5 0" Foreground="{DynamicResource TextColourMuted}" FontSize="12"/>
      </Grid>

      <StackPanel Orientation="Horizontal" Spacing="5" x:Name="cont_Platforms">
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
