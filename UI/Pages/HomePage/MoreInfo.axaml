<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="1000" x:Class="UI.Pages.HomePage.MoreInfo"
  xmlns:models="clr-namespace:Models.Data;assembly=Models" x:DataType="models:ProjectInfo" Width="300"
  xmlns:controls="clr-namespace:UI.Controls"
  xmlns:popups="clr-namespace:UI.Popups">
  <Border BorderThickness="1 0 0 0" BorderBrush="{DynamicResource ButtonBorder}" Padding="10">
    <Grid>
      <Grid x:Name="cont_Message">
        <Label HorizontalAlignment="Center" VerticalAlignment="Center">Nothing Selected</Label>
      </Grid>

      <StackPanel Spacing="15" x:Name="cont_Main">
        <!-- ICON -->
        <Border HorizontalAlignment="Stretch" Height="150" Background="{DynamicResource BackgroundColourDark}" CornerRadius="{DynamicResource CornerRadius_Element}" ClipToBounds="True">
          <Image x:Name="img" Stretch="UniformToFill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Border>

        <StackPanel Spacing="10" Margin="8 0">
          <!-- Title bar -->
          <StackPanel Orientation="Vertical">
            <Label Content="{Binding name}"/>

            <!-- Veersion selection -->
            <controls:ButtonWrapper Label="{Binding version}" Classes="Transparent" x:Name="inp_Version" HasPopupIcon="True">
              <controls:ButtonWrapper.Icon>
                <Viewbox Height="12" Width="12" Margin="0 0 10 0">
                  <Path Data="m 12.8497 1 v 3.9324 l 3.4868 2.0108 c 0.0279 0.0167 0.0501 0.0446 0.0668 0.0724 c 0.0223 0.0278 0.0279 0.0613 0.0279 0.0947 c 0 0.0334 -0.0056 0.0668 -0.0279 0.1003 c -0.0167 0.0278 -0.039 0.0501 -0.0668 0.0724 l -4.1441 2.384 c -0.0557 0.039 -0.1281 0.0557 -0.195 0.0557 c -0.0668 0 -0.1337 -0.0167 -0.195 -0.0557 l -4.1441 -2.384 c -0.0279 -0.0167 -0.0501 -0.0446 -0.0668 -0.0724 c -0.0167 -0.0279 -0.0279 -0.0613 -0.0279 -0.0947 c 0 -0.0334 0.0111 -0.0668 0.0279 -0.1003 c 0.0167 -0.0279 0.039 -0.0501 0.0668 -0.0724 l 3.4868 -2.0052 v -3.938 l -8.8953 5.13 v 10.2544 l 3.4144 -1.9662 v -4.0215 c 0 -0.0334 0.0056 -0.0668 0.0223 -0.0947 c 0.0167 -0.0279 0.0446 -0.0501 0.0724 -0.0724 c 0.0278 -0.0167 0.0613 -0.0223 0.1003 -0.0223 c 0.0334 0 0.0668 0.0056 0.0947 0.0223 l 4.1441 2.3895 c 0.0613 0.0334 0.1114 0.0836 0.1448 0.1448 c 0.0334 0.0557 0.0501 0.1225 0.0501 0.1949 v 4.7735 c 0 0.0334 -0.0056 0.0668 -0.0278 0.1003 c -0.0167 0.0279 -0.039 0.0557 -0.0668 0.0724 c -0.0334 0.0167 -0.0668 0.0223 -0.1003 0.0223 c -0.0334 0 -0.0668 -0.0056 -0.0947 -0.0223 l -3.4868 -2.0108 l -3.4144 1.9662 l 8.8953 5.13 l 8.8953 -5.13 l -3.4144 -1.9662 l -3.4868 2.0108 c -0.0278 0.0167 -0.0613 0.0223 -0.0947 0.0223 c -0.0334 0 -0.0668 -0.0111 -0.0947 -0.0279 c -0.0334 -0.0167 -0.0557 -0.039 -0.0724 -0.0668 c -0.0167 -0.0334 -0.0279 -0.0668 -0.0279 -0.1003 v -4.7735 c 0 -0.0724 0.0167 -0.1393 0.0501 -0.1949 c 0.039 -0.0613 0.0836 -0.1114 0.1448 -0.1448 l 4.1441 -2.3895 c 0.0278 -0.0167 0.0613 -0.0223 0.0947 -0.0223 c 0.0334 0 0.0668 0.0056 0.1003 0.0223 c 0.0278 0.0223 0.0501 0.0446 0.0668 0.0724 c 0.0223 0.0279 0.0279 0.0613 0.0279 0.1003 v 4.016 l 3.4144 1.9662 v -10.2544 l -8.8953 -5.13 z" Fill="{DynamicResource TextColour}" />
                </Viewbox>
              </controls:ButtonWrapper.Icon>
            </controls:ButtonWrapper>
          </StackPanel>

          <!-- Controls -->
          <StackPanel Spacing="5">
            <StackPanel.Styles>
              <Style Selector="Button">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="0 10"/>
              </Style>
            </StackPanel.Styles>

            <controls:DropDownButton x:Name="btn_OpenProject" ButtonLabel="Open Project" Height="45"/>

            <controls:ButtonWrapper x:Name="btn_OpenIDE" Label="Open in Editor" Height="45"/>
            <controls:ButtonWrapper x:Name="btn_OpenExplorer" Label="Reveal in Explorer" Height="45"/>

            <!-- Terminal -->
            <Grid ColumnDefinitions="* * * *" Height="45">
              <controls:ButtonWrapper Margin="0 0 0 0" Grid.Column="0" x:Name="btn_Terminal" HorizontalContentAlignment="Center" ToolTip="Shell">
                <controls:ButtonWrapper.Icon>
                  <Viewbox Height="20">
                    <Grid>
                      <Path Data="M6 9a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1h-3A.5.5 0 0 1 6 9M3.854 4.146a.5.5 0 1 0-.708.708L4.793 6.5 3.146 8.146a.5.5 0 1 0 .708.708l2-2a.5.5 0 0 0 0-.708z"/>
                      <Path Data="M2 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z"/>
                    </Grid>
                  </Viewbox>
                </controls:ButtonWrapper.Icon>
              </controls:ButtonWrapper>

              <!-- Move -->
              <controls:ButtonWrapper Margin="5 0 0 0" Grid.Column="1" x:Name="btn_Move" HorizontalContentAlignment="Center" ToolTip="Move">
                <controls:ButtonWrapper.Icon>
                  <Viewbox Height="23" Margin="0 0 4 4">
                    <Grid>
                      <Path Data="M6 3.5a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-2a.5.5 0 0 0-1 0v2A1.5 1.5 0 0 0 6.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2h-8A1.5 1.5 0 0 0 5 3.5v2a.5.5 0 0 0 1 0z"/>
                      <Path Data="M11.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5H1.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708z"/>
                    </Grid>
                  </Viewbox>
                </controls:ButtonWrapper.Icon>
              </controls:ButtonWrapper>

              <!-- Clone -->
              <controls:ButtonWrapper Margin="5 0 0 0" Grid.Column="2" x:Name="btn_Clone" HorizontalContentAlignment="Center" ToolTip="Duplicate">
                <controls:ButtonWrapper.Icon>
                  <Viewbox Height="20">
                    <Path Fill="{DynamicResource TextColour}" Data="M4 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zM2 5a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-1h1v1a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h1v1z"/>
                  </Viewbox>
                </controls:ButtonWrapper.Icon>
              </controls:ButtonWrapper>

              <!-- Delete -->
              <controls:ButtonWrapper Margin="5 0 0 0" Grid.Column="3" x:Name="btn_Delete" HorizontalContentAlignment="Center" ToolTip="Delete">
                <controls:ButtonWrapper.Icon>
                  <Viewbox Height="20" Margin="0 0 1 0">
                    <Path Data="M2.5 1a1 1 0 0 0-1 1v1a1 1 0 0 0 1 1H3v9a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V4h.5a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H10a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1zm3 4a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 .5-.5M8 5a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7A.5.5 0 0 1 8 5m3 .5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 1 0"/>
                  </Viewbox>
                </controls:ButtonWrapper.Icon>
              </controls:ButtonWrapper>
            </Grid>
          </StackPanel>
        </StackPanel>

        <Border Background="{DynamicResource ButtonBorder}" Height="1" HorizontalAlignment="Stretch" Margin="8 0"/>

        <!-- Meta -->
        <StackPanel Orientation="Vertical" Margin="8 0" x:Name="cont_MetaData">
          <StackPanel.Styles>
            <Style Selector="StackPanel > StackPanel > Label">
              <Setter Property="Foreground" Value="{DynamicResource TextColourMuted}"/>
              <Setter Property="FontSize" Value="12"/>
            </Style>
            <Style Selector="StackPanel > Grid > Label">
              <Setter Property="Foreground" Value="{DynamicResource TextColourMuted}"/>
              <Setter Property="FontSize" Value="12"/>
              <Setter Property="Width" Value="100"/>
            </Style>
            <Style Selector="StackPanel > Grid > TextBlock">
              <Setter Property="Foreground" Value="{DynamicResource TextColourMuted}"/>
              <Setter Property="FontSize" Value="12"/>
            </Style>
            <Style Selector="StackPanel > StackPanel">
              <Setter Property="Orientation" Value="Horizontal"/>
            </Style>
          </StackPanel.Styles>

          <Label Content="Details" Foreground="{DynamicResource TextColour}" Margin="0 0 0 10"/>

          <Grid ColumnDefinitions="Auto *">
            <Label Content="Path" />
            <TextBlock Text="{Binding directory}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Grid.Column="2"/>
          </Grid>
          <StackPanel>
            <Label Width="100" Content="Last Opened" />
            <Label Content="{Binding getLastOpenedTxt}" />
          </StackPanel>
          <StackPanel>
            <Label Width="100" Content="Created" />
            <Label Content="{Binding getCreatedTxt}" />
          </StackPanel>
          <StackPanel>
            <Label Width="100" Content="Unity Version" />
            <Label Content="{Binding version}" />
          </StackPanel>
          <StackPanel>
            <Label Width="100" Content="Render Pipeline" />
            <Label Content="{Binding renderPipelineName}" />
          </StackPanel>
          <StackPanel>
            <Label Width="100" Content="Project Size" />
            <Label Content="{Binding getSizeTxt}" />
          </StackPanel>
          <StackPanel>
            <Label Width="100" Content="Packages" />
            <Label Content="{Binding packages}" />
          </StackPanel>

        </StackPanel>

        <!-- Tags -->
        <StackPanel Margin="8 0">
          <Grid>
            <Label HorizontalAlignment="Left" Foreground="{DynamicResource TextColour}">Tags</Label>

            <controls:ButtonWrapper HorizontalAlignment="Right" Classes="Transparent" x:Name="btn_AddTag">
              <controls:ButtonWrapper.Icon>
                <Viewbox Width="18" Height="18">
                  <Path Fill="{DynamicResource TextColour}" Data="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
                </Viewbox>
              </controls:ButtonWrapper.Icon>
            </controls:ButtonWrapper>
          </Grid>
          <WrapPanel x:Name="cont_Tags" Margin="5 0 0 0" ItemSpacing="5" LineSpacing="5"/>
        </StackPanel>

        <!-- Collections -->
        <StackPanel Margin="8 0">
          <Grid>
            <Label HorizontalAlignment="Left" Foreground="{DynamicResource TextColour}">Collections</Label>

            <controls:ButtonWrapper HorizontalAlignment="Right" Classes="Transparent" x:Name="btn_AddCollection">
              <controls:ButtonWrapper.Icon>
                <Viewbox Width="18" Height="18">
                  <Path Fill="{DynamicResource TextColour}" Data="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
                </Viewbox>
              </controls:ButtonWrapper.Icon>
            </controls:ButtonWrapper>
          </Grid>
          <WrapPanel x:Name="cont_Collections" Margin="5 0 0 0" ItemSpacing="5" LineSpacing="5"/>
        </StackPanel>

        <StackPanel Margin="8 0" Spacing="5">
          <Label HorizontalAlignment="Left" Foreground="{DynamicResource TextColour}">Notes</Label>
          <TextBox TextWrapping="Wrap" FontSize="12" x:Name="inp_Notes" Background="{DynamicResource ElementBackground}" BorderThickness="1" BorderBrush="{DynamicResource ButtonBorder}" CornerRadius="{DynamicResource CornerRadius_Element}"/>
          <controls:ButtonWrapper Label="Save" x:Name="btn_SaveNotes" HorizontalAlignment="Right" Classes="Primary"/>
        </StackPanel>

      </StackPanel>
    </Grid>
  </Border>
</UserControl>
