<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Pages.HomePage.Page"
  xmlns:local="clr-namespace:UI.Pages.HomePage"
  xmlns:controls="clr-namespace:UI.Controls">
  <Grid ColumnDefinitions="* Auto">
    <Grid RowDefinitions="200 *">
      <Grid>
        <controls:DropDownButton x:Name="btn_NewProject" ButtonLabel="New Project"/>
      </Grid>


      <WrapPanel Grid.Row="1" x:Name="grid_Content" />
    </Grid>

    <local:MoreInfo Grid.Column="1" x:Name="control_MoreInfo"/>
  </Grid>
</UserControl>
