<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Pages.HomePage.Sidebar_DriveUsage" x:Name="root">
  <StackPanel Orientation="Vertical" Spacing="5">
    <Label Content="{Binding #root.DriveName}" FontSize="12"/>
    <Border Height="10" CornerRadius="{DynamicResource CornerRadius_Menu}" ClipToBounds="True" BorderThickness="1" Background="{DynamicResource ElementBackground}" BorderBrush="{DynamicResource ButtonBorder}">
      <StackPanel x:Name="cont_Slices" HorizontalAlignment="Left" VerticalAlignment="Stretch" Orientation="Horizontal"/>
    </Border>
  </StackPanel>
</UserControl>
