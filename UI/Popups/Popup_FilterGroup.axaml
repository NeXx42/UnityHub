<UserControl xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="UI.Popups.Popup_FilterGroup" x:Name="root">
  <StackPanel Orientation="Vertical">
    <Border x:Name="btn" CornerRadius="0" Background="{DynamicResource ButtonBackground}" Cursor="Hand">
      <Grid>
        <Label Content="{Binding #root.Header}" HorizontalAlignment="Left" Padding="0" Margin="5"/>
        <Label Content="-" HorizontalAlignment="Right" Padding="0" Margin="5"/>
      </Grid>
    </Border>

    <Border x:Name="cont_Container" IsVisible="False">
      <StackPanel x:Name="cont" Margin="5">
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
